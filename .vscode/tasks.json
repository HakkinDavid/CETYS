{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "g++ compile and run in external terminal",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++23",
                "${file}",
                "-o",
                "${fileDirname}/compiled/${fileBasenameNoExtension}"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "C/C++ compile and run in external terminal"
        },
        {
            "label": "Run in external terminal",
            "type": "shell",
            "command": "osascript",
            "args": [
                "-e",
                "tell app \"Terminal\" to do script \"\\\"${fileDirname}/compiled/${fileBasenameNoExtension}\\\"; exit\""
            ],
            "dependsOn": "g++ compile and run in external terminal",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
